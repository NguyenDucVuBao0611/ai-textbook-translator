# --- CONFIGURATION FOR TRANSLATION MODELS ---

# Stage 1: Literal Translation Model
# Currently using NLLB-200 base model as placeholder. 
# Swap this with your fine-tuned model once it's uploaded to Hugging Face, e.g. vubao0611/nllb-envi-ai-textbook-stage1
HF_MODEL_STAGE1=facebook/nllb-200-distilled-600M

# Stage 2: Explanatory Rewrite Model
# Leave empty for now. Backend will automatically bypass Stage 2 DL and fall back to rule-based glossary replacement.
# Once fine-tuned, swap with your model, e.g. vubao0611/nllb-envi-ai-textbook-stage2
HF_MODEL_STAGE2=

# --- INTERACTIVE AI ASSISTANT CONFIGURATION ---
# Optional: Set Claude/OpenAI API keys for interactive side-panel question answering
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_API_URL=http://localhost:11434
